<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:SubjectsManager.Pages"
             xmlns:models="clr-namespace:SubjectsManager.DTOModels.Subject;assembly=SubjectsManager.DTOModels"
             xmlns:vms="clr-namespace:SubjectsManager.ViewModels"
             x:Class="SubjectsManager.Pages.LessonDetailsPage"
             x:DataType="vms:LessonDetailsViewModel"
             Title="LessonDetailsPage"
             IsEnabled="{Binding IsNotBusy}">
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="10,20" Spacing="10">
                <Label
                    Text="Date"/>
                <Label
                    Text="{Binding Date, StringFormat='{}{0:dd\\.MM\\.yyyy}'}"
                    Margin="10,0"></Label>
                <Label
                    Text="Start time"/>
                <Label
                    Text="{Binding StartTime, StringFormat='{}{0:hh\\:mm}'}"
                    Margin="10,0"></Label>
                <Label
                    Text="End time"/>
                <Label
                    Text="{Binding EndTime, StringFormat='{}{0:hh\\:mm}'}"
                    Margin="10,0"></Label>
                <Label
                    Text="Topic"/>
                <Label
                    Text="{Binding Topic}"
                    Margin="10,0"></Label>
                <Label
                    Text="Type"/>
                <Label
                    Text="{Binding Type, Converter={StaticResource EnumToDisplayName}}"
                    Margin="10,0"></Label>
                <Label
                    Text="Duration"/>
                <Label
                    Text="{Binding Duration, StringFormat='{}{0:hh} h {0:mm} m'}"
                    Margin="10,0"></Label>
            </VerticalStackLayout>
        </ScrollView>
        <BoxView
            IsVisible="{Binding IsBusy}"
            BackgroundColor="Gray"
            Opacity="0.2"
            InputTransparent="False"/>
        <ActivityIndicator
            Color="Magenta"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>
    </Grid>
</ContentPage>